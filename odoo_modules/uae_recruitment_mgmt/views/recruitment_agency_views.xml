<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_recruitment_agency_list" model="ir.ui.view">
        <field name="name">recruitment.agency.list</field>
        <field name="model">recruitment.agency</field>
        <field name="arch" type="xml">
            <list string="Recruitment Agencies">
                <field name="code"/>
                <field name="name"/>
                <field name="agency_type"/>
                <field name="specialization"/>
                <field name="country_id"/>
                <field name="candidate_count" sum="Total Candidates"/>
                <field name="deployed_count" sum="Total Deployed"/>
                <field name="placement_success_rate" avg="Avg Success Rate" widget="percentage"/>
                <field name="quality_rating"/>
                <field name="license_status" 
                       decoration-success="license_status == 'valid'"
                       decoration-warning="license_status == 'pending_renewal'"
                       decoration-danger="license_status in ['expired', 'suspended']"/>
                <field name="state" 
                       decoration-success="state == 'active'"
                       decoration-info="state == 'draft'"
                       decoration-muted="state in ['inactive', 'terminated']"
                       decoration-danger="state == 'blacklisted'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_recruitment_agency_form" model="ir.ui.view">
        <field name="name">recruitment.agency.form</field>
        <field name="model">recruitment.agency</field>
        <field name="arch" type="xml">
            <form string="Recruitment Agency">
                <header>
                    <button name="action_activate" string="Activate" type="object" 
                            class="oe_highlight" invisible="state == 'active'"/>
                    <button name="action_deactivate" string="Deactivate" type="object" 
                            invisible="state in ['inactive', 'blacklisted', 'terminated']"/>
                    <button name="action_blacklist" string="Blacklist" type="object" 
                            confirm="Are you sure you want to blacklist this agency?"
                            invisible="state == 'blacklisted'"/>
                    <button name="action_terminate" string="Terminate" type="object" 
                            confirm="Are you sure you want to terminate this agency?"
                            invisible="state == 'terminated'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active"/>
                </header>
                
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_candidates" type="object" class="oe_stat_button" icon="fa-users">
                            <div class="o_stat_info">
                                <field name="candidate_count" class="o_stat_value"/>
                                <span class="o_stat_text">Candidates</span>
                            </div>
                        </button>
                        <button name="action_view_placements" type="object" class="oe_stat_button" icon="fa-briefcase">
                            <div class="o_stat_info">
                                <field name="deployed_count" class="o_stat_value"/>
                                <span class="o_stat_text">Deployments</span>
                            </div>
                        </button>
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="BLACKLISTED" bg_color="text-bg-danger" invisible="state != 'blacklisted'"/>
                    <widget name="web_ribbon" title="TERMINATED" bg_color="text-bg-dark" invisible="state != 'terminated'"/>
                    <widget name="web_ribbon" title="INACTIVE" bg_color="text-bg-warning" invisible="state != 'inactive'"/>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="code" readonly="1" class="oe_inline" placeholder="Auto-generated"/>
                            - <field name="name" placeholder="Agency Name..." class="oe_inline"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Agency Information">
                            <field name="agency_type"/>
                            <field name="specialization"/>
                            <field name="deployment_capacity"/>
                            <field name="quality_rating"/>
                            <field name="partner_id"/>
                            <field name="onboarding_date"/>
                        </group>
                        <group string="License &amp; Compliance">
                            <field name="license_number"/>
                            <field name="license_expiry_date"/>
                            <field name="license_status" readonly="1" 
                                   decoration-success="license_status == 'valid'"
                                   decoration-danger="license_status in ['expired', 'suspended']"/>
                            <field name="mohre_registered"/>
                            <field name="mohre_registration_number" invisible="not mohre_registered"/>
                        </group>
                    </group>

                    <group>
                        <group string="Contact Information">
                            <field name="contact_person"/>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="mobile" widget="phone"/>
                            <field name="website" widget="url"/>
                        </group>
                        <group string="Address">
                            <field name="street" placeholder="Street..."/>
                            <field name="street2" placeholder="Street2..."/>
                            <field name="city"/>
                            <field name="state_id"/>
                            <field name="zip"/>
                            <field name="country_id" options="{'no_create': True}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Source Countries &amp; Services">
                            <group>
                                <field name="source_country_ids" widget="many2many_tags" 
                                       options="{'color_field': 'name', 'no_create': True}"
                                       placeholder="Select countries from which this agency recruits..."/>
                            </group>
                            <separator string="Services Offered"/>
                            <field name="services_offered" placeholder="Describe services offered by this agency..."/>
                        </page>

                        <page string="Performance Metrics">
                            <group>
                                <group string="Deployment Statistics">
                                    <field name="active_candidate_count"/>
                                    <field name="deployed_count"/>
                                    <field name="placement_success_rate" widget="percentage"/>
                                    <field name="average_deployment_time"/> days
                                    <field name="last_deployment_date"/>
                                </group>
                                <group string="Financial Metrics">
                                    <field name="currency_id" invisible="1"/>
                                    <field name="commission_rate" widget="percentage"/>
                                    <field name="total_commission" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="outstanding_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </group>
                        </page>

                        <page string="Notes &amp; History">
                            <field name="notes" placeholder="Internal notes about this agency..."/>
                        </page>
                    </notebook>
                </sheet>

                <!-- Chatter -->
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_recruitment_agency_kanban" model="ir.ui.view">
        <field name="name">recruitment.agency.kanban</field>
        <field name="model">recruitment.agency</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="code"/>
                <field name="agency_type"/>
                <field name="specialization"/>
                <field name="country_id"/>
                <field name="candidate_count"/>
                <field name="deployed_count"/>
                <field name="placement_success_rate"/>
                <field name="quality_rating"/>
                <field name="license_status"/>
                <field name="state"/>
                
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="o_kanban_record_subtitle">
                                        <field name="code"/> - <field name="country_id"/>
                                    </span>
                                </div>
                                <div class="o_dropdown_kanban dropdown">
                                    <a class="dropdown-toggle o-no-caret btn" role="button" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a role="menuitem" type="object" name="action_activate" class="dropdown-item">Activate</a>
                                        <a role="menuitem" type="object" name="action_deactivate" class="dropdown-item">Deactivate</a>
                                        <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                    </div>
                                </div>
                            </div>

                            <div class="o_kanban_record_body">
                                <div class="o_kanban_tags_section">
                                    <field name="agency_type" widget="badge"/>
                                    <field name="specialization" widget="badge"/>
                                </div>
                                <ul>
                                    <li><i class="fa fa-users"/> <field name="candidate_count"/> Candidates</li>
                                    <li><i class="fa fa-briefcase"/> <field name="deployed_count"/> Deployed</li>
                                    <li><i class="fa fa-percent"/> <field name="placement_success_rate" widget="percentage"/> Success Rate</li>
                                </ul>
                            </div>

                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="quality_rating" widget="priority"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection" 
                                           options="{'classes': {'draft': 'secondary', 'active': 'success', 'inactive': 'warning', 'blacklisted': 'danger', 'terminated': 'dark'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_recruitment_agency_search" model="ir.ui.view">
        <field name="name">recruitment.agency.search</field>
        <field name="model">recruitment.agency</field>
        <field name="arch" type="xml">
            <search string="Search Agencies">
                <field name="name" string="Agency" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="country_id"/>
                <field name="source_country_ids"/>
                <field name="license_number"/>
                <field name="contact_person"/>
                
                <filter string="Active Agencies" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Inactive" name="inactive" domain="[('state', '=', 'inactive')]"/>
                <filter string="Blacklisted" name="blacklisted" domain="[('state', '=', 'blacklisted')]"/>
                
                <separator/>
                <filter string="Blue Collar Specialists" name="blue_collar" 
                        domain="[('specialization', '=', 'blue_collar')]"/>
                <filter string="White Collar Specialists" name="white_collar" 
                        domain="[('specialization', '=', 'white_collar')]"/>
                <filter string="International Agencies" name="international" 
                        domain="[('agency_type', '=', 'international')]"/>
                
                <separator/>
                <filter string="Valid License" name="license_valid" 
                        domain="[('license_status', '=', 'valid')]"/>
                <filter string="Expired License" name="license_expired" 
                        domain="[('license_status', '=', 'expired')]"/>
                <filter string="MOHRE Registered" name="mohre_registered" 
                        domain="[('mohre_registered', '=', True)]"/>
                
                <separator/>
                <filter string="High Performers (&gt;70% Success)" name="high_performers" 
                        domain="[('placement_success_rate', '&gt;=', 70)]"/>
                <filter string="Top Rated (5 Stars)" name="top_rated" 
                        domain="[('quality_rating', '=', '5')]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Agency Type" name="group_type" context="{'group_by': 'agency_type'}"/>
                    <filter string="Specialization" name="group_specialization" context="{'group_by': 'specialization'}"/>
                    <filter string="Country" name="group_country" context="{'group_by': 'country_id'}"/>
                    <filter string="License Status" name="group_license" context="{'group_by': 'license_status'}"/>
                    <filter string="Quality Rating" name="group_rating" context="{'group_by': 'quality_rating'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_recruitment_agency" model="ir.actions.act_window">
        <field name="name">Recruitment Agencies</field>
        <field name="res_model">recruitment.agency</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_recruitment_agency_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first recruitment agency!
            </p>
            <p>
                Track external recruitment agencies that source candidates for your business.<br/>
                Monitor their performance, deployment capabilities, and candidate quality.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_recruitment_agency"
              name="Agencies"
              parent="menu_recruitment_root"
              action="action_recruitment_agency"
              sequence="25"/>

</odoo>
