# Environment Configuration
# Copy this file to .env and fill in your values

# Node Environment (development, staging, production)
NODE_ENV=production

# API Configuration
VITE_API_URL=https://eigermarvelhr.com
VITE_API_TIMEOUT=30000

# Odoo Configuration
VITE_ODOO_URL=https://eigermarvelhr.com
VITE_ODOO_DATABASE=eigermarvel
VITE_ODOO_USERNAME=admin
VITE_ODOO_PASSWORD=your_password_here

# MCP Server Configuration
VITE_MCP_ENABLED=true
VITE_MCP_URL=http://localhost:3001
VITE_MCP_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_AUTO_SYNC=true
VITE_SYNC_INTERVAL=300000

# Analytics (Optional)
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_KEY=

# Debug Mode (set to false in production)
VITE_DEBUG_MODE=false
